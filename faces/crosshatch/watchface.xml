<?xml version="1.0" encoding="utf-8"?>
<WatchFace width="450" height="450">
  <Metadata key="CLOCK_TYPE" value="ANALOG" />
  <Metadata key="PREVIEW_TIME" value="10:08:00" />

  <UserConfigurations>
    <ColorConfiguration id="lineColor" displayName="Color" defaultValue="white">
      <ColorOption id="white" colors="#E0E0E0" />
      <ColorOption id="red" colors="#FF6B6B" />
      <ColorOption id="blue" colors="#6BB8FF" />
      <ColorOption id="gold" colors="#FFD700" />
      <ColorOption id="green" colors="#6BFF8A" />
    </ColorConfiguration>
  </UserConfigurations>

  <Scene backgroundColor="#000000">

    <!-- 12 hour ticks — static 6px dots on a radius-215 circle (near bezel) -->
    <Ellipse x="222" y="7"   width="6" height="6"> <Fill color="[CONFIGURATION.lineColor.0]" /> </Ellipse>
    <Ellipse x="330" y="36"  width="6" height="6"> <Fill color="[CONFIGURATION.lineColor.0]" /> </Ellipse>
    <Ellipse x="408" y="115" width="6" height="6"> <Fill color="[CONFIGURATION.lineColor.0]" /> </Ellipse>
    <Ellipse x="437" y="222" width="6" height="6"> <Fill color="[CONFIGURATION.lineColor.0]" /> </Ellipse>
    <Ellipse x="408" y="330" width="6" height="6"> <Fill color="[CONFIGURATION.lineColor.0]" /> </Ellipse>
    <Ellipse x="330" y="408" width="6" height="6"> <Fill color="[CONFIGURATION.lineColor.0]" /> </Ellipse>
    <Ellipse x="222" y="437" width="6" height="6"> <Fill color="[CONFIGURATION.lineColor.0]" /> </Ellipse>
    <Ellipse x="115" y="408" width="6" height="6"> <Fill color="[CONFIGURATION.lineColor.0]" /> </Ellipse>
    <Ellipse x="36"  y="330" width="6" height="6"> <Fill color="[CONFIGURATION.lineColor.0]" /> </Ellipse>
    <Ellipse x="7"   y="222" width="6" height="6"> <Fill color="[CONFIGURATION.lineColor.0]" /> </Ellipse>
    <Ellipse x="36"  y="115" width="6" height="6"> <Fill color="[CONFIGURATION.lineColor.0]" /> </Ellipse>
    <Ellipse x="115" y="36"  width="6" height="6"> <Fill color="[CONFIGURATION.lineColor.0]" /> </Ellipse>

    <!-- Main rotating group — rotates by hour angle -->
    <Group x="0" y="0" width="450" height="450" name="crossGroup"
           pivotX="0.5" pivotY="0.5">
      <Transform target="angle"
        value="([HOUR_0_23] % 12) * 30 + [MINUTE] * 0.5" />
      <Variant mode="AMBIENT" target="alpha" value="100" />

      <!-- Pair A: vertical lines (hour-indicating pair). Top = hour side, solid. -->
      <!-- Line A1 (left of center) — moves LEFT from center -->
      <Rectangle x="222" y="0" width="3" height="450">
        <Transform target="x"
          value="222 - ([MINUTE] &lt; 15 ? [MINUTE] * 5 / 3 : ([MINUTE] &lt; 30 ? (30 - [MINUTE]) * 5 / 3 : ([MINUTE] &lt; 45 ? ([MINUTE] - 30) * 5 / 3 : (60 - [MINUTE]) * 5 / 3)))" />
        <Fill color="[CONFIGURATION.lineColor.0]" />
      </Rectangle>

      <!-- Line A2 (right of center) — moves RIGHT from center -->
      <Rectangle x="225" y="0" width="3" height="450">
        <Transform target="x"
          value="225 + ([MINUTE] &lt; 15 ? [MINUTE] * 5 / 3 : ([MINUTE] &lt; 30 ? (30 - [MINUTE]) * 5 / 3 : ([MINUTE] &lt; 45 ? ([MINUTE] - 30) * 5 / 3 : (60 - [MINUTE]) * 5 / 3)))" />
        <Fill color="[CONFIGURATION.lineColor.0]" />
      </Rectangle>

      <!-- Pair A fade overlays on bottom halves (y=225..450), dim toward bezel -->
      <Rectangle x="222" y="225" width="3" height="225">
        <Transform target="x"
          value="222 - ([MINUTE] &lt; 15 ? [MINUTE] * 5 / 3 : ([MINUTE] &lt; 30 ? (30 - [MINUTE]) * 5 / 3 : ([MINUTE] &lt; 45 ? ([MINUTE] - 30) * 5 / 3 : (60 - [MINUTE]) * 5 / 3)))" />
        <Fill>
          <LinearGradient startX="0" startY="225" endX="0" endY="450"
                          colors="#00000000 #90000000" positions="0 1" />
        </Fill>
      </Rectangle>
      <Rectangle x="225" y="225" width="3" height="225">
        <Transform target="x"
          value="225 + ([MINUTE] &lt; 15 ? [MINUTE] * 5 / 3 : ([MINUTE] &lt; 30 ? (30 - [MINUTE]) * 5 / 3 : ([MINUTE] &lt; 45 ? ([MINUTE] - 30) * 5 / 3 : (60 - [MINUTE]) * 5 / 3)))" />
        <Fill>
          <LinearGradient startX="0" startY="225" endX="0" endY="450"
                          colors="#00000000 #90000000" positions="0 1" />
        </Fill>
      </Rectangle>

      <!-- Pair B: horizontal lines (perpendicular pair) -->
      <!-- Line B1 (above center) — moves UP from center -->
      <Rectangle x="0" y="222" width="450" height="3">
        <Transform target="y"
          value="222 - ([MINUTE] &lt; 15 ? [MINUTE] * 5 / 3 : ([MINUTE] &lt; 30 ? (30 - [MINUTE]) * 5 / 3 : ([MINUTE] &lt; 45 ? ([MINUTE] - 30) * 5 / 3 : (60 - [MINUTE]) * 5 / 3)))" />
        <Fill color="[CONFIGURATION.lineColor.0]" />
      </Rectangle>

      <!-- Line B2 (below center) — moves DOWN from center -->
      <Rectangle x="0" y="225" width="450" height="3">
        <Transform target="y"
          value="225 + ([MINUTE] &lt; 15 ? [MINUTE] * 5 / 3 : ([MINUTE] &lt; 30 ? (30 - [MINUTE]) * 5 / 3 : ([MINUTE] &lt; 45 ? ([MINUTE] - 30) * 5 / 3 : (60 - [MINUTE]) * 5 / 3)))" />
        <Fill color="[CONFIGURATION.lineColor.0]" />
      </Rectangle>

      <!-- Pair B fade overlays — left halves dim toward x=0, right halves dim toward x=450 -->
      <Rectangle x="0" y="222" width="225" height="3">
        <Transform target="y"
          value="222 - ([MINUTE] &lt; 15 ? [MINUTE] * 5 / 3 : ([MINUTE] &lt; 30 ? (30 - [MINUTE]) * 5 / 3 : ([MINUTE] &lt; 45 ? ([MINUTE] - 30) * 5 / 3 : (60 - [MINUTE]) * 5 / 3)))" />
        <Fill>
          <LinearGradient startX="0" startY="0" endX="225" endY="0"
                          colors="#90000000 #00000000" positions="0 1" />
        </Fill>
      </Rectangle>
      <Rectangle x="225" y="222" width="225" height="3">
        <Transform target="y"
          value="222 - ([MINUTE] &lt; 15 ? [MINUTE] * 5 / 3 : ([MINUTE] &lt; 30 ? (30 - [MINUTE]) * 5 / 3 : ([MINUTE] &lt; 45 ? ([MINUTE] - 30) * 5 / 3 : (60 - [MINUTE]) * 5 / 3)))" />
        <Fill>
          <LinearGradient startX="225" startY="0" endX="450" endY="0"
                          colors="#00000000 #90000000" positions="0 1" />
        </Fill>
      </Rectangle>
      <Rectangle x="0" y="225" width="225" height="3">
        <Transform target="y"
          value="225 + ([MINUTE] &lt; 15 ? [MINUTE] * 5 / 3 : ([MINUTE] &lt; 30 ? (30 - [MINUTE]) * 5 / 3 : ([MINUTE] &lt; 45 ? ([MINUTE] - 30) * 5 / 3 : (60 - [MINUTE]) * 5 / 3)))" />
        <Fill>
          <LinearGradient startX="0" startY="0" endX="225" endY="0"
                          colors="#90000000 #00000000" positions="0 1" />
        </Fill>
      </Rectangle>
      <Rectangle x="225" y="225" width="225" height="3">
        <Transform target="y"
          value="225 + ([MINUTE] &lt; 15 ? [MINUTE] * 5 / 3 : ([MINUTE] &lt; 30 ? (30 - [MINUTE]) * 5 / 3 : ([MINUTE] &lt; 45 ? ([MINUTE] - 30) * 5 / 3 : (60 - [MINUTE]) * 5 / 3)))" />
        <Fill>
          <LinearGradient startX="225" startY="0" endX="450" endY="0"
                          colors="#00000000 #90000000" positions="0 1" />
        </Fill>
      </Rectangle>

    </Group>

  </Scene>
</WatchFace>
